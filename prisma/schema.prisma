generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String
  password   String? // bcrypt hash; null = cannot log in yet
  role       String   @default("user") // admin=A (root), editor=B (lider/muhasebe), user=C (üye)
  department String?
  status     String   @default("active")
  avatar     String?
  title      String? // B/C pozisyonu: Ekip Lideri, Muhasebe, Editör, Muhabir...
  managerId  String? // bağlı olduğu ekip lideri (B kullanıcısı)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  manager     User?  @relation("TeamManager", fields: [managerId], references: [id], onDelete: SetNull)
  teamMembers User[] @relation("TeamManager")

  tips             Tip[]            @relation("TipReporter")
  tasks            Task[]           @relation("TaskAssignee")
  tickets          Ticket[]         @relation("TicketAssignee")
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
  warnsReceived    Warn[]           @relation("WarnTarget")
  warnsIssued      Warn[]           @relation("WarnIssuer")
  payments         PaymentRequest[] @relation("PaymentUser")
}

model Tip {
  id         String @id @default(uuid())
  tipNumber  String @unique // e.g. TIP-001
  subject    String
  content    String
  source     String // E.g., Anonim, Veli İhbarı
  sourceType String @default("email") // email, phone
  priority   String @default("normal") // low, normal, high, urgent
  status     String @default("new") // new, investigating, verified, converted, rejected

  reporterId String?
  reporter   User?   @relation("TipReporter", fields: [reporterId], references: [id])
  draftId    String? // site ihbarından üretilen AiDraft bağı

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String  @id @default(uuid())
  firstName String
  lastName  String
  email     String  @unique
  phone     String?
  company   String?
  status    String  @default("active") // active, inactive
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id           String  @id @default(uuid())
  companyName  String
  contactName  String
  email        String  @unique
  phone        String?
  status       String  @default("active") // active, inactive
  satisfaction Int     @default(100) // 0-100 score

  projects  Project[]
  invoices  Invoice[]
  estimates Estimate[]
  tickets   Ticket[]
  contracts Contract[]
  proposals Proposal[]
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id       String    @id @default(uuid())
  name     String
  status   String    @default("active") // active, completed, on_hold
  progress Int       @default(0) // 0-100
  deadline DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  tasks     Task[]
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo") // todo, in_progress, review, done
  priority    String    @default("normal") // low, normal, high, urgent
  dueDate     DateTime?
  recurrence  String? // daily | weekly | monthly — done olunca sonraki örnek üretilir

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  assigneeId String?
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  deletedAt  DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String    @id @default(uuid())
  name      String
  company   String?
  value     Float     @default(0)
  status    String    @default("new") // new, contacted, proposal, won, lost
  priority  String    @default("normal") // low, normal, high, urgent
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id             String    @id @default(uuid())
  invoiceNo      String    @unique
  amount         Float // genel toplam (KDV dahil) — kalemlerden hesaplanır
  currency       String    @default("TRY")
  subtotal       Float? // ara toplam (KDV hariç)
  vatTotal       Float? // toplam KDV
  discount       Float? // indirim tutarı
  status         String    @default("unpaid") // unpaid, paid, overdue, cancelled
  dueDate        DateTime?
  lastReminderAt DateTime? // son gecikme hatırlatması
  reminderCount  Int       @default(0)
  sentAt         DateTime? // müşteriye e-posta ile gönderildi
  pdfUrl         String? // üretilen PDF (object storage/data)
  notes          String?
  advertiserId   String? // reklam faturaları (Advertiser bağı)

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  items     InvoiceItem[]
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Fatura satır kalemi (Finans 2.0 — kalemli fatura + KDV).
model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  vatRate     Float   @default(20) // KDV oranı %
  order       Int     @default(0)

  @@index([invoiceId])
}

model Estimate {
  id         String    @id @default(uuid())
  estimateNo String    @unique
  amount     Float
  status     String    @default("draft") // draft, sent, accepted, rejected
  validUntil DateTime?
  sourceId     String? // dönüştürüldüyse köken kayıt
  convertedToId String? // dönüştürülen hedef (Contract/Invoice) id
  publicToken  String?   @unique // müşteri onay linki (imzasız)

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id          String    @id @default(uuid())
  category    String
  amount      Float
  description String?
  receiptUrl  String?
  date        DateTime  @default(now())
  deletedAt   DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model News {
  id          String    @id @default(uuid())
  title       String
  category    String
  author      String
  status      String    @default("draft") // draft, published
  views       Int       @default(0)
  publishDate DateTime?
  wpId        Int?      @unique // WordPress post ID (synced articles)
  url         String? // canonical URL on the WordPress site

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id           String    @id @default(uuid())
  email        String    @unique
  source       String    @default("website")
  status       String    @default("active") // pending, active, unsubscribed
  confirmToken String? // çift-onay (double opt-in) doğrulama token'ı
  confirmedAt  DateTime?
  unsubToken   String?   @unique // tek-tık abonelikten çıkma
  tags         String? // JSON: ilgi ilçeleri/kategorileri (segment)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  newsletterRecipients NewsletterRecipient[]
}

model Advertiser {
  id          String  @id @default(uuid())
  company     String
  contactName String
  email       String
  phone       String?
  activeAds   Int     @default(0)
  totalSpent  Float   @default(0)
  status      String  @default("active") // active, inactive
  reportToken String? @unique // token'lı public performans raporu (self-servis)

  campaigns AdCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(uuid())
  title       String
  date        DateTime
  type        String   @default("meeting") // meeting, deadline, event
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id          String  @id @default(uuid())
  ticketNo    String  @unique
  subject     String
  description String?
  status      String  @default("open") // open, in_progress, resolved, closed
  priority    String  @default("normal") // low, normal, high, urgent

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id           String    @id @default(uuid())
  name         String
  type         String    @default("pdf") // pdf, word, excel, image, other
  size         Int       @default(0) // in bytes
  url          String?
  mime         String? // gerçek MIME türü
  driveFileId  String? // Google Drive dosya id'si (Drive'a yüklenenler)
  uploadedById String? // yükleyen kullanıcı
  folderId     String?
  folder       Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)
  deletedAt    DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folderId])
}

/// Depo klasörü: hiyerarşik ağaç + erişim kuralları (seviye / belirli kullanıcı / şifre).
model Folder {
  id           String    @id @default(uuid())
  name         String
  parentId     String?
  parent       Folder?   @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     Folder[]  @relation("FolderTree")
  minLevel     String    @default("C") // A | B | C — bu seviyenin altı göremez
  restricted   Boolean   @default(false) // true → yalnız FolderAccess listesindekiler (+A)
  passwordHash String? // şifreli klasör (bcrypt); null = şifresiz
  driveFolderId String? // eşlenen Google Drive klasörü (büyük video akışı/senkron)
  createdById  String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  documents Document[]
  access    FolderAccess[]

  @@index([parentId])
}

/// Kısıtlı klasörlere belirli kullanıcı erişimi.
model FolderAccess {
  id       String  @id @default(uuid())
  folderId String
  folder   Folder  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId   String
  canWrite Boolean @default(false)

  @@unique([folderId, userId])
}

/// Sayfa görünürlük kuralı: taban RBAC'ın üzerine A/B tarafından yönetilen istisnalar.
/// targetUserId dolu → kişiye özel kural; yoksa targetRole ('B'|'C') rol geneli kural (yalnız A koyabilir).
model AccessRule {
  id           String   @id @default(uuid())
  path         String // üst segment: '/invoices', '/reports'...
  targetRole   String? // 'B' | 'C'
  targetUserId String?
  allow        Boolean // true = eriş, false = engelle
  grantedById  String?
  createdAt    DateTime @default(now())

  @@index([path])
  @@index([targetUserId])
}

model Contract {
  id        String    @id @default(uuid())
  title     String
  value     Float     @default(0)
  status    String    @default("draft") // draft, active, expired
  progress  Int       @default(0) // 0-100
  startDate DateTime?
  endDate   DateTime?
  sourceId      String? // köken (Estimate/Proposal) id
  convertedToId String? // üretilen Invoice id
  publicToken   String?   @unique // müşteri onay/e-imza linki

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proposal {
  id          String  @id @default(uuid())
  title       String
  description String?
  value       Float   @default(0)
  status      String  @default("draft") // draft, sent, approved, rejected
  sourceId      String?
  convertedToId String?
  publicToken   String?   @unique

  clientId  String?
  client    Client?   @relation(fields: [clientId], references: [id])
  deletedAt DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Announcement {
  id       String @id @default(uuid())
  title    String
  content  String
  target   String @default("Herkes") // Herkes, Ekip, Musteri
  priority String @default("normal") // low, normal, high
  author   String @default("Admin")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id       String  @id @default(uuid())
  title    String
  content  String
  category String  @default("Genel")
  color    String  @default("#6c5ce7")
  shared   Boolean @default(false)
  favorite Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id       String  @id @default(uuid())
  title    String
  content  String?
  category String  @default("Genel")
  views    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id      String  @id @default(uuid())
  content String
  read    Boolean @default(false)

  senderId    String
  sender      User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String
  recipient   User   @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([senderId, recipientId])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @default("info") // tip, invoice_paid, project_completed, client, task, news, contract, info
  title     String
  link      String? // CRM içi hedef sayfa, ör. /tips
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String // JSON string
  updatedAt DateTime @updatedAt
}

model Newsletter {
  id         String    @id @default(uuid())
  subject    String
  intro      String? // editör girişi / AI özeti
  content    String // gönderilen HTML/metin gövdesi
  status     String    @default("draft") // draft, sent
  recipients Int       @default(0) // gönderim anındaki abone sayısı
  sentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdCampaign {
  id          String    @id @default(uuid())
  name        String
  placement   String    @default("banner") // banner, native, video, sidebar
  status      String    @default("active") // active, paused, ended
  startDate   DateTime?
  endDate     DateTime?
  budget      Float     @default(0)
  impressions Int       @default(0)
  clicks      Int       @default(0)
  creativeUrl String? // reklam görseli (URL)
  targetUrl   String? // tıklama hedefi
  weight      Int       @default(1) // rotasyon ağırlığı
  districts   String? // JSON: ilçe hedefleme

  advertiserId String?
  advertiser   Advertiser? @relation(fields: [advertiserId], references: [id])
  events       AdEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Reklam gösterim/tık olayı (gerçek envanter ölçümü).
model AdEvent {
  id         String     @id @default(uuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type       String // impression | click
  ipHash     String?
  createdAt  DateTime   @default(now())

  @@index([campaignId, createdAt])
}

// ── RBAC: kullanıcı uyarıları (warn sistemi) ──
model Warn {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation("WarnTarget", fields: [userId], references: [id], onDelete: Cascade)
  reason     String
  severity   String   @default("normal") // low, normal, high
  issuedById String?
  issuedBy   User?    @relation("WarnIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

// ── Ortak harcama bütçesi (yönetici çıkarır, kullanıcılara paylaştırılır) ──
model Budget {
  id          String   @id @default(uuid())
  title       String
  description String?
  totalAmount Float    @default(0)
  createdBy   String? // oluşturan yöneticinin adı
  status      String   @default("open") // open, closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests PaymentRequest[]
}

// ── Ödeme talebi / maaş kaydı — kişinin paneline düşer, 'ödedim' ile kapanır ──
model PaymentRequest {
  id      String    @id @default(uuid())
  kind    String    @default("collection") // collection (ortak harcama tahsilatı) | salary (maaş)
  title   String
  amount  Float
  status  String    @default("pending") // pending, paid, cancelled
  note    String?
  dueDate DateTime?
  paidAt  DateTime?

  userId   String
  user     User    @relation("PaymentUser", fields: [userId], references: [id], onDelete: Cascade)
  budgetId String?
  budget   Budget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ══════════ WORDPRESS AI HABER MOTORU ══════════

// Haber kaynağı (RSS / Google News). Panelden yönetilir.
model NewsSource {
  id            String    @id @default(uuid())
  name          String
  feedUrl       String
  type          String    @default("rss") // rss | google_news
  enabled       Boolean   @default(true)
  needsUA       Boolean   @default(false) // WAF: tarayıcı User-Agent gerekir
  trustScore    Int       @default(50) // 0-100 kaynak güveni (ağırlıklı konu seçimi)
  sourceType    String    @default("local") // official | local | aggregator | social
  district      String? // kaynağın coğrafi kapsamı (ilçe)
  lastFetchedAt DateTime?
  lastItemCount Int? // son koşuda çekilen öğe sayısı (sağlık)
  lastError     String? // son çekim hatası (sağlık)
  notes         String?
  createdAt     DateTime  @default(now())

  items FeedItem[]
}

// Kaynaklardan çekilen ham haber öğesi (dedup + konu bulma için).
model FeedItem {
  id          String      @id @default(uuid())
  sourceId    String?
  source      NewsSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceName  String? // kaynak silinse de isim kalsın
  title       String
  link        String
  guidHash    String      @unique // dedup: link/başlık hash
  summary     String?
  pubDate     DateTime?
  fetchedAt   DateTime    @default(now())
  usedInDraft Boolean     @default(false)
  district    String? // sözlük/AI ile çıkarılan ilçe
  isLocal     Boolean     @default(true) // Çanakkale-dışı gürültü filtresi
  embedding   String? // JSON float[] — kümeleme (çoklu-kaynak teyidi)
  clusterId   String? // aynı olayı anlatan öğelerin kümesi
  importance  Float? // yenilik/önem skoru
  mediaUrl    String? // kaynak medya (gerçek foto sourcing)

  @@index([fetchedAt])
  @@index([clusterId])
}

// AI üretilen haber taslağı — onay kuyruğunun kalbi (taslak→onay→yayın).
model AiDraft {
  id              String   @id @default(uuid())
  topic           String
  title           String?
  body            String? // Postgres'te text
  category        String?
  tags            String? // JSON dizi (string)
  seoTitle        String?
  metaDescription String?
  socialPost      String?
  imageUrl        String? // Imagen görseli (data URI / URL), "temsili" etiketli
  sources         String? // JSON: atıf verilen linkler
  confidence      Float? // fact-check güven skoru 0-1
  status          String   @default("pending") // pending | approved | rejected | published
  reviewerId      String? // onaylayan CRM kullanıcısı (id)
  reviewerName    String?
  wpId            Int? // yayınlanınca WP post id
  articleId       String? // yayınlanınca site makalesi (SiteArticle) id
  newsType        String   @default("daily") // breaking | daily | weekly
  district        String? // AI'ın çıkardığı Çanakkale ilçesi
  qualityScore    Float? // 0-100: güven + özgünlük + kaynak sayısı + doluluk
  originalityScore Float? // kaynağa benzerlik (düşük = kopya riski)
  sourceCount     Int? // fact-check bağımsız kaynak sayısı
  hasContradiction Boolean @default(false) // kaynaklar arası çelişki bayrağı
  editorNote      String? // redaksiyon notu (editörden editöre)
  scheduledAt     DateTime? // planlı yayın zamanı
  igAssets        String? // JSON: üretilen Instagram görsel referansları
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

/// Denetim kaydı: hassas işlemlerin (ödeme, ayar, ekip, uyarı, yayın...) kim/ne/ne zaman izi.
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  userName  String?
  action    String // created | updated | deleted | paid | approved | rejected | published ...
  entity    String // invoice, payment, warn, setting, team, aiDraft ...
  entityId  String?
  detail    String? // kısa Türkçe açıklama
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@index([userId])
}

// ═══════════════ ÖZEL HABER SİTESİ (canakkale.network) ═══════════════

// Sitede yayınlanan haber/makale — AI taslağından, WP içe aktarımından veya elle.
model SiteArticle {
  id              String        @id @default(uuid())
  slug            String        @unique
  title           String
  summary         String? // spot / kısa özet
  body            String // HTML gövde
  categorySlug    String?
  category        SiteCategory? @relation(fields: [categorySlug], references: [slug], onDelete: SetNull)
  tags            String? // JSON dizi (string)
  imageUrl        String? // kapak görseli (URL veya data URI)
  imageAlt        String?
  imageIsAi       Boolean       @default(false) // "Temsili görsel" rozeti
  videoUrl        String? // röportaj/video haberler (YouTube vb.)
  authorName      String        @default("Çanakkale Network")
  authorId        String? // CRM kullanıcısı (varsa)
  status          String        @default("draft") // draft | published | archived
  newsType        String        @default("daily") // breaking | daily | weekly | manual
  isBreaking      Boolean       @default(false) // son dakika şeridi
  isFeatured      Boolean       @default(false) // anasayfa manşet
  isEditorPick    Boolean       @default(false) // editörün seçimi
  publishedAt     DateTime?
  views           Int           @default(0)
  seoTitle        String?
  metaDescription String?
  sourceDraftId   String? // köken AiDraft id
  sourceLinks     String? // JSON: kaynak atıf linkleri
  district        String? // Çanakkale ilçesi (Merkez/Biga/Çan...) — ilçe filtreleme ekseni
  gallery         String? // JSON [{url,alt}] — foto galeri (harici URL)
  correctionNote  String? // yayın sonrası düzeltme metni (basın hukuku)
  correctedAt     DateTime?
  retractedAt     DateTime? // geri çekme (retraction)
  retractionNote  String?
  authorSlug      String? // yazar/köşe hub bağı (Author.slug)
  scheduledAt     DateTime? // planlı yayın (status='scheduled' → cron yayınlar)
  wpId            Int?          @unique // WP'den içe aktarılan haberler
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  events          ArticleEvent[]

  @@index([status, publishedAt])
  @@index([categorySlug])
  @@index([categorySlug, publishedAt])
  @@index([district, publishedAt])
  @@index([isBreaking, publishedAt])
}

// Site kategorileri (nav + haber sınıflandırma), CRM'den yönetilir.
model SiteCategory {
  slug      String    @id
  name      String
  color     String? // vurgu rengi (opsiyonel)
  order     Int       @default(0)
  showInNav Boolean   @default(true)
  articles  SiteArticle[]
}

// Statik site sayfaları (hakkımızda, künye, sözleşmeler...) — CRM'den düzenlenir.
model SitePage {
  slug            String   @id
  title           String
  content         String // HTML
  status          String   @default("published") // published | hidden
  seoTitle        String?
  metaDescription String?
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// "Ekibimize Katıl" başvuruları — form şeması Setting('joinForm') içinde.
model JoinApplication {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  data      String // JSON: dinamik form yanıtları
  status    String   @default("new") // new | reviewed | accepted | rejected
  note      String? // değerlendirme notu
  convertedLeadId String? // kabul edilince oluşturulan Lead id (İK/lead akışı)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// Site analitik olay tablosu (görüntülenme/okuma/paylaşım) — first-party, KVKK-dostu.
model ArticleEvent {
  id           String      @id @default(uuid())
  articleId    String
  article      SiteArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  slug         String
  type         String // view | read_complete | share | outbound_click
  referrerHost String?
  deviceType   String? // mobile | desktop | tablet
  district     String?
  sessionHash  String? // anonim oturum (KVKK: kişisel veri değil)
  createdAt    DateTime    @default(now())

  @@index([articleId, createdAt])
  @@index([createdAt])
  @@index([type, createdAt])
}

// Nöbetçi eczane (il + 11 ilçe, günlük) — yerel kamu-hizmet verisi.
model NobetciEczane {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  district  String // Merkez, Biga, Çan...
  name      String
  address   String?
  phone     String?
  lat       Float?
  lng       Float?
  mapsUrl   String?
  source    String   @default("api") // api | scrape | manual
  createdAt DateTime @default(now())

  @@unique([date, district, name])
  @@index([date, district])
}

// ══════════ P1 ══════════

// Bülten per-subscriber gönderim + açılma/tık takibi.
model NewsletterRecipient {
  id           String     @id @default(uuid())
  newsletterId String
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  token        String     @unique // açılma pikseli + tık sarmalayıcı
  openedAt     DateTime?
  clickedAt    DateTime?
  createdAt    DateTime   @default(now())

  @@index([newsletterId])
}

// Web push aboneliği (son dakika bildirimi). İlçe-hedefli olabilir.
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  district  String?
  createdAt DateTime @default(now())

  @@index([district])
}

// Yazar / köşe yazarı (yazar hub sayfaları).
model Author {
  slug        String   @id
  name        String
  bio         String?
  avatar      String?
  title       String? // ünvan (ör. "Genel Yayın Yönetmeni")
  isColumnist Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tekrarlayan fatura şablonu (aylık/çeyreklik retainer → otomatik Invoice).
model RecurringInvoice {
  id        String    @id @default(uuid())
  clientId  String?
  title     String
  items     String // JSON: kalem listesi (InvoiceItem şekli)
  currency  String    @default("TRY")
  interval  String    @default("monthly") // monthly | quarterly | yearly
  nextRunAt DateTime?
  active    Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active, nextRunAt])
}

// Basit e-imza kaydı (teklif/sözleşme onayı — hukuki iz).
model Signature {
  id        String   @id @default(uuid())
  entity    String // estimate | proposal | contract
  entityId  String
  name      String
  ip        String?
  hash      String? // içerik özeti (bütünlük)
  signedAt  DateTime @default(now())

  @@index([entity, entityId])
}

// Kaydedilen rapor şablonu (özelleştirilebilir raporlama).
model SavedReport {
  id        String   @id @default(uuid())
  name      String
  type      String // revenue | collection | vat | editor ...
  config    String // JSON: tarih aralığı + metrikler
  ownerId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Sosyal medya yayın kuyruğu (çoklu-kanal yayın — site+bülten+sosyal).
model SocialPost {
  id        String    @id @default(uuid())
  articleId String?
  platform  String    @default("instagram") // instagram | x | facebook
  text      String
  status    String    @default("queued") // queued | posted | skipped
  postedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([status, createdAt])
}

// Feribot/vapur tarifesi (admin-yönetimli; GESTAŞ resmi API yok).
model FerrySchedule {
  id        String  @id @default(uuid())
  route     String // "Çanakkale-Eceabat" ...
  departTime String // "HH:MM"
  days      String  @default("hergun") // hergun | haftaici | haftasonu
  operator  String  @default("GESTAŞ")
  season    String? // yaz | kis
  active    Boolean @default(true)

  @@index([route, active])
}

// AI çağrı/maliyet logu (model yönlendirme + kota takibi).
model AiUsageLog {
  id           String   @id @default(uuid())
  fn           String // discoverTopics | factCheck | writeArticle | image | embed ...
  model        String
  inputTokens  Int?
  outputTokens Int?
  images       Int?
  costUsd      Float?
  ms           Int?
  ok           Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
